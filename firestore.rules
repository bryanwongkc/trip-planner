rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSharedOverrideDoc() {
      return request.resource.data.keys().hasOnly(['items', 'updatedAt']) &&
        request.resource.data.items is map;
    }

    match /trips/{tripId}/overrides/shared {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isSharedOverrideDoc();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
